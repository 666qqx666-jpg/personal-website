---
import ThemeToggle from './ThemeToggle.astro';
import { profile } from '../data/profile';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/'); // 处理 GitHub Pages 子路径（强制尾斜杠）
const links = [
  { label: '首页', href: base },
  { label: '项目经历', href: `${base}projects/` },
  { label: 'AI 落地', href: `${base}ai/` },
  { label: '思考成长', href: `${base}thinking/` },
  { label: '关于', href: `${base}about/` },
];
---
<header class="nav">
  <div class="container nav-inner">
    <a class="brand" href={base}>{profile.name}</a>
    <nav class="links">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
      <a class="resume" href={`${base}${profile.resumePdf}`} download>简历 PDF</a>
      <ThemeToggle />
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: var(--nav-bg);
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 60px; }
  .brand { font-weight: 800; color: var(--text); }
  .links { display: flex; align-items: center; gap: 18px; }
  .links a { color: var(--text); font-size: 14px; }
  .links a:hover { color: var(--accent); }
  .resume { border: 1px solid var(--accent); border-radius: 999px; padding: 4px 12px; color: var(--accent) !important; }
  @media (max-width: 640px) {
    .links { gap: 10px; font-size: 13px; }
    .links a:not(.resume):not(:last-child) { display: none; }
  }
</style>
