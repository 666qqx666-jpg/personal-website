---
interface Props {
  title: string; hook?: string; tags?: string[]; href?: string; cover?: string;
}
const { title, hook = '', tags = [], href, cover } = Astro.props;
const Tag = href ? 'a' : 'div';
---
<Tag class="card" href={href}>
  <div class="cover" style={cover ? `background:${cover}` : undefined}>
    <span class="shine"></span>
  </div>
  <div class="body">
    <h3>{title}</h3>
    {hook && <p class="hook">{hook}</p>}
    {tags.length > 0 && <div class="tags">{tags.map((t) => <span>{t}</span>)}</div>}
  </div>
</Tag>

<style>
  .card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    color: var(--text);
    position: relative;
    transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease), border-color 0.35s var(--ease);
  }
  .card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: var(--accent);
  }
  .cover { height: 104px; background: var(--grad); position: relative; overflow: hidden; }
  .shine {
    position: absolute; inset: 0;
    background: linear-gradient(120deg, transparent 30%, rgba(255, 255, 255, 0.28) 50%, transparent 70%);
    transform: translateX(-110%);
    transition: transform 0.7s var(--ease);
  }
  .card:hover .shine { transform: translateX(110%); }
  .body { padding: 18px; }
  .body h3 { font-size: 17px; font-weight: 700; }
  .hook { color: var(--muted); font-size: 13.5px; margin-top: 8px; line-height: 1.5; }
  .tags { display: flex; gap: 7px; flex-wrap: wrap; margin-top: 14px; }
  .tags span {
    font-size: 11px; border: 1px solid var(--border); border-radius: 999px;
    padding: 3px 10px; color: var(--muted); background: var(--bg-soft);
  }
</style>
