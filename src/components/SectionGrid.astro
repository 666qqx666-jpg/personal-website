---
import Card from './Card.astro';
interface Item { title: string; hook?: string; tags?: string[]; href?: string; cover?: string; }
interface Props { title: string; icon?: string; items: Item[]; }
const { title, icon = '', items } = Astro.props;
---
<section class="section-pad">
  <div class="container">
    <h2 class="sg-title reveal">{icon} {title}</h2>
    <div class="grid">
      {items.map((it, i) => (
        <div class="reveal" data-delay={String((i % 3) + 1)}><Card {...it} /></div>
      ))}
    </div>
  </div>
</section>

<style>
  .sg-title { font-size: 28px; font-weight: 800; margin-bottom: 28px; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 22px; }
</style>
