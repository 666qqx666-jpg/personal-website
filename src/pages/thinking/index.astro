---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionGrid from '../../components/SectionGrid.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const items = [
  {
    title: '置身钉内 → 产品机会',
    hook: '从钉钉 ONE 复盘里读出企业 AI 的责任流、风险兜底和组织学习方法',
    tags: ['阅读总结', '企业 AI', 'To B 产品'],
    href: `${base}ai/zhi-shen-ding-nei/`,
  },
  { title: '产品方法论卡片合集', hook: '需求定位四问 / 用户买单信号 / PRD 审查', tags: ['方法论'] },
  { title: '转型故事 + 周度复盘', hook: '一个传统 PM 怎么跳进 AI', tags: ['成长'] },
];
---
<BaseLayout title="思考与成长"><SectionGrid title="思考与成长" icon="📖" items={items} /></BaseLayout>
