    --mo-decision: var(--c-violet);
    --mo-growth: #22c55e;
    --mo-risk: #f97316;
    --mo-blocked: var(--c-problem);
  }
  .membership-operations-deck section { width: 100%; }
  .scene-shell { width: min(1120px, 100%); margin-inline: auto; }
