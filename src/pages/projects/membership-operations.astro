  .membership-operations-nav { position: fixed; z-index: 18; bottom: 1rem; left: 50%; translate: -50% 0; display: flex; gap: .3rem; padding: .5rem; border: 1px solid var(--glass-border); border-radius: 999px; background: var(--chrome-bg); }
