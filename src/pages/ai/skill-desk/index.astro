---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { deskTabs, productLanes, skillDeskItems, skillLabItems } from '../../../data/skillDesk';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const stableCount = skillDeskItems.filter((item) => item.maturity === 'stable').length;
const iteratingCount = skillDeskItems.filter((item) => item.maturity === 'iterating').length;
const productCount = skillDeskItems.filter((item) => item.productization !== 'personal').length;
const hrefFor = (href?: string) => href ? `${base}${href.replace(/^\//, '')}` : undefined;
---
<BaseLayout
  title="Skill Desk — QQ星"
  description="把实用 AI workflow 拆成可解释、可验证、可继续产品化的 skill 方法库"
  bodyClass="skill-desk-shell"
>
  <section class="section-pad skill-desk-page">
    <div class="container">
      <div class="desk-hero reveal">
        <p class="eyebrow">AI Workflow Method Library</p>
        <h1>Skill Desk</h1>
        <p class="hero-copy">把深度阅读、复盘、需求发现、PRD、竞品分析、报价、记忆控制等高频 AI workflow 拆成可解释、可验证、可继续产品化的 agent skill。</p>
        <div class="desk-stats" aria-label="Skill Desk stats">
          <div><strong>{stableCount}</strong><span>已稳定使用</span></div>
          <div><strong>{iteratingCount}</strong><span>迭代中</span></div>
          <div><strong>{productCount}</strong><span>可产品化候选</span></div>
        </div>
      </div>

      <nav class="desk-tabs reveal" aria-label="Skill categories">
        {deskTabs.map((tab) => <a href={`#${tab === '全部' ? 'all' : tab}`}>{tab}</a>)}
      </nav>

      <div id="all" class="desk-grid">
        {skillDeskItems.map((item, index) => {
          const href = hrefFor(item.href);
          const isAbsorbed = item.variant === 'absorbed';
          const cardClass = `skill-card reveal ${href ? 'flagship-card' : ''} ${isAbsorbed ? 'absorbed-card' : ''}`;
          return href ? (
            <a class={cardClass} data-delay={String((index % 3) + 1)} href={href}>
              <span class="card-kicker">{item.category}</span>
              {isAbsorbed && <span class="absorbed-ribbon">{item.absorbedLabel}</span>}
              <h2>{item.title}</h2>
              <p>{item.problem}</p>
              {isAbsorbed && <div class="absorbed-note">{item.absorbedNote}</div>}
              <div class="meta-row">
                <span>{item.maturityLabel}</span>
                <span>{item.productizationLabel}</span>
              </div>
              <div class="chip-row">{item.outputs.map((output) => <b>{output}</b>)}</div>
            </a>
          ) : (
            <article class={cardClass} data-delay={String((index % 3) + 1)}>
              <span class="card-kicker">{item.category}</span>
              {isAbsorbed && <span class="absorbed-ribbon">{item.absorbedLabel}</span>}
              <h2>{item.title}</h2>
              <p>{item.problem}</p>
              {isAbsorbed && <div class="absorbed-note">{item.absorbedNote}</div>}
              <div class="meta-row">
                <span>{item.maturityLabel}</span>
                <span>{item.productizationLabel}</span>
              </div>
              <div class="chip-row">{item.outputs.map((output) => <b>{output}</b>)}</div>
            </article>
          );
        })}
      </div>

      <section class="skill-lab reveal" aria-label="Skill Lab">
        <div class="lab-intro">
          <p class="eyebrow">Skill Lab</p>
          <h2>Skill Lab</h2>
          <p>这里不是正式 Skill Desk，也不进入统计。只有经过真实项目使用、暴露问题并完成二次调整后，才升级成详情页。</p>
        </div>
        <div class="lab-grid">
          {skillLabItems.map((item) => (
            <article class="lab-item">
              <div class="lab-topline">
                <span class="card-kicker">{item.category}</span>
                <span class="status-pill">{item.statusLabel}</span>
              </div>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
              <div class="validation-note">
                <strong>验证触发</strong>
                <span>{item.validationTrigger}</span>
              </div>
              <div class="chip-row lab-chips">{item.signals.map((signal) => <b>{signal}</b>)}</div>
            </article>
          ))}
        </div>
      </section>

      <section class="product-lane reveal" aria-label="Productization lanes">
        <div>
          <p class="eyebrow">Productization</p>
          <h2>每个 skill 都保留一条产品化判断线</h2>
        </div>
        <div class="lane-grid">
          {productLanes.map((lane) => (
            <article>
              <h3>{lane.title}</h3>
              <p>{lane.copy}</p>
            </article>
          ))}
        </div>
      </section>

      <a class="harness-link reveal" href={`${base}ai/knowledge-harness/`}>这些 skill 最终进入 Personal Knowledge Harness</a>
    </div>
  </section>

  <style>
    :global(body.skill-desk-shell) {
      --bg: #f7f9fd;
      --bg-soft: #edf3fa;
      --surface: rgba(255, 255, 255, 0.82);
      --surface-2: rgba(255, 255, 255, 0.72);
      --text: #0f172a;
      --muted: #5f6b7c;
      --border: rgba(15, 23, 42, 0.1);
      --accent: #0891b2;
      --accent-2: #7c3aed;
      --accent-3: #059669;
      --grad: linear-gradient(100deg, #2563eb 0%, #7c3aed 48%, #0891b2 100%);
      --nav-bg: rgba(255, 255, 255, 0.76);
      --shadow: 0 14px 36px rgba(15, 23, 42, 0.08);
      --shadow-lg: 0 20px 52px rgba(15, 23, 42, 0.14);
      --desk-page-bg:
        radial-gradient(620px 420px at 18% 0%, rgba(37, 99, 235, 0.13), transparent 62%),
        radial-gradient(760px 520px at 88% 12%, rgba(124, 58, 237, 0.1), transparent 64%),
        radial-gradient(720px 560px at 55% 100%, rgba(8, 145, 178, 0.08), transparent 62%),
        linear-gradient(180deg, #f7f9fd 0%, #edf3fa 48%, #f8fbff 100%);
      --desk-grid-line: rgba(15, 23, 42, 0.055);
      --desk-footer-bg: #f8fbff;
      --desk-chip-text: #334155;
      --desk-chip-bg: rgba(255, 255, 255, 0.58);
      --desk-stat-bg: linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(255, 255, 255, 0.46));
      --desk-absorbed-bg:
        linear-gradient(135deg, rgba(251, 191, 36, 0.13), rgba(255, 255, 255, 0.52)),
        rgba(255, 255, 255, 0.72);
      --desk-absorbed-kicker: #b45309;
      --desk-ribbon-text: #854d0e;
      --desk-ribbon-bg: rgba(251, 191, 36, 0.14);
      --desk-note-text: #475569;
      --desk-note-bg: rgba(251, 191, 36, 0.1);
      --desk-lab-card-bg:
        linear-gradient(135deg, rgba(148, 163, 184, 0.13), rgba(8, 145, 178, 0.08)),
        rgba(255, 255, 255, 0.7);
      --desk-lab-kicker: #475569;
      --desk-status-text: #854d0e;
      --desk-status-bg: rgba(251, 191, 36, 0.14);
      --desk-validation-strong: #0891b2;
      --desk-validation-text: #334155;
      --desk-harness: #0e7490;
      background: var(--bg);
    }
    :global(:root[data-theme='dark'] body.skill-desk-shell) {
      --bg: #070b14;
      --bg-soft: #0a1020;
      --surface: rgba(15, 22, 38, 0.82);
      --surface-2: rgba(13, 20, 36, 0.78);
      --text: #e8ecf5;
      --muted: #96a3b8;
      --border: rgba(255, 255, 255, 0.1);
      --accent: #22d3ee;
      --accent-2: #8b5cf6;
      --accent-3: #34d399;
      --grad: linear-gradient(100deg, #4f8cff 0%, #8b5cf6 50%, #22d3ee 100%);
      --nav-bg: rgba(7, 11, 20, 0.78);
      --shadow: 0 16px 42px rgba(0, 0, 0, 0.28);
      --shadow-lg: 0 22px 58px rgba(0, 0, 0, 0.42);
      --desk-page-bg:
        radial-gradient(620px 420px at 18% 0%, rgba(79, 140, 255, 0.18), transparent 62%),
        radial-gradient(760px 520px at 88% 12%, rgba(139, 92, 246, 0.14), transparent 64%),
        radial-gradient(720px 560px at 55% 100%, rgba(34, 211, 238, 0.1), transparent 62%),
        linear-gradient(180deg, #070b14 0%, #0a1020 48%, #070b14 100%);
      --desk-grid-line: rgba(255, 255, 255, 0.045);
      --desk-footer-bg: #070b14;
      --desk-chip-text: #c8d3e4;
      --desk-chip-bg: rgba(255, 255, 255, 0.045);
      --desk-stat-bg: linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.02));
      --desk-absorbed-bg:
        linear-gradient(135deg, rgba(251, 191, 36, 0.045), rgba(255, 255, 255, 0.018)),
        rgba(15, 22, 38, 0.72);
      --desk-absorbed-kicker: rgba(251, 191, 36, 0.78);
      --desk-ribbon-text: rgba(248, 231, 178, 0.84);
      --desk-ribbon-bg: rgba(251, 191, 36, 0.065);
      --desk-note-text: rgba(200, 211, 228, 0.82);
      --desk-note-bg: rgba(255, 255, 255, 0.028);
      --desk-lab-card-bg:
        linear-gradient(135deg, rgba(148, 163, 184, 0.09), rgba(34, 211, 238, 0.045)),
        rgba(15, 22, 38, 0.56);
      --desk-lab-kicker: #cbd5e1;
      --desk-status-text: rgba(248, 231, 178, 0.88);
      --desk-status-bg: rgba(251, 191, 36, 0.075);
      --desk-validation-strong: #67e8f9;
      --desk-validation-text: #c8d3e4;
      --desk-harness: #67e8f9;
      background: var(--bg);
    }
    :global(body.skill-desk-shell .nav) {
      border-bottom-color: var(--border);
    }
    :global(body.skill-desk-shell .footer) {
      margin-top: 0;
      background: var(--desk-footer-bg);
      border-top-color: var(--border);
    }
    .skill-desk-page {
      position: relative;
      overflow: hidden;
      min-height: calc(100vh - 60px);
      padding-top: 72px;
      background: var(--desk-page-bg);
      color: var(--text);
      isolation: isolate;
    }
    .skill-desk-page::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -1;
      background-image:
        linear-gradient(var(--desk-grid-line) 1px, transparent 1px),
        linear-gradient(90deg, var(--desk-grid-line) 1px, transparent 1px);
      background-size: 54px 54px;
      mask-image: radial-gradient(ellipse 88% 70% at 50% 22%, #000 24%, transparent 82%);
    }
    .skill-desk-page :global(.reveal) {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .desk-hero {
      display: grid;
      gap: 1rem;
      max-width: 860px;
    }
    .eyebrow,
    .card-kicker {
      color: var(--accent-3);
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0;
      text-transform: uppercase;
    }
    .desk-hero h1 {
      background: var(--grad);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      font-size: 4.5rem;
      letter-spacing: 0;
      line-height: 1;
    }
    .hero-copy {
      max-width: 720px;
      color: var(--muted);
      font-size: 1.05rem;
      line-height: 1.8;
    }
    .desk-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
      margin-top: 0.6rem;
      max-width: 620px;
    }
    .desk-stats div,
    .skill-card,
    .product-lane,
    .lane-grid article {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(16px);
    }
    .desk-stats div {
      padding: 16px;
      background: var(--desk-stat-bg), var(--surface);
    }
    .desk-stats strong {
      display: block;
      font-size: 1.6rem;
      line-height: 1;
    }
    .desk-stats span {
      color: var(--muted);
      font-size: 0.84rem;
    }
    .desk-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 34px 0 24px;
    }
    .desk-tabs a {
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 7px 12px;
      color: var(--desk-chip-text);
      background: var(--surface-2);
      font-size: 0.88rem;
    }
    .desk-tabs a:hover {
      border-color: rgba(34, 211, 238, 0.58);
      color: var(--text);
      background: rgba(34, 211, 238, 0.1);
    }
    .desk-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
    }
    .skill-card {
      display: grid;
      gap: 12px;
      min-height: 292px;
      padding: 20px;
      color: var(--text);
      transition: transform 0.25s var(--ease), border-color 0.25s var(--ease), box-shadow 0.25s var(--ease);
    }
    a.skill-card:hover {
      transform: translateY(-4px);
      border-color: var(--accent);
      box-shadow: var(--shadow-lg);
    }
    .flagship-card {
      background:
        linear-gradient(135deg, rgba(34, 211, 238, 0.16), rgba(139, 92, 246, 0.12)),
        var(--surface);
    }
    .absorbed-card {
      border-color: rgba(251, 191, 36, 0.24);
      border-style: dashed;
      background: var(--desk-absorbed-bg);
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);
    }
    .absorbed-card .card-kicker {
      color: var(--desk-absorbed-kicker);
    }
    a.absorbed-card:hover {
      border-color: rgba(251, 191, 36, 0.38);
      box-shadow: 0 16px 36px rgba(0, 0, 0, 0.28);
    }
    .absorbed-ribbon {
      display: inline-flex;
      width: fit-content;
      border: 1px solid rgba(251, 191, 36, 0.3);
      border-radius: 999px;
      padding: 4px 9px;
      color: var(--desk-ribbon-text);
      background: var(--desk-ribbon-bg);
      font-size: 0.74rem;
      font-weight: 700;
      line-height: 1.35;
    }
    .absorbed-note {
      border-left: 2px solid rgba(251, 191, 36, 0.34);
      border-radius: 6px;
      padding: 8px 10px;
      color: var(--desk-note-text);
      background: var(--desk-note-bg);
      font-size: 0.82rem;
      line-height: 1.55;
    }
    .skill-card h2 {
      font-size: 1.12rem;
      letter-spacing: 0;
    }
    .skill-card p {
      color: var(--muted);
      font-size: 0.92rem;
      line-height: 1.65;
    }
    .meta-row,
    .chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      align-self: end;
    }
    .meta-row span,
    .chip-row b {
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 4px 9px;
      color: var(--desk-chip-text);
      background: var(--desk-chip-bg);
      font-size: 0.75rem;
      font-weight: 600;
    }
    .product-lane {
      display: grid;
      grid-template-columns: minmax(220px, 0.8fr) minmax(0, 1.6fr);
      gap: 20px;
      margin-top: 28px;
      padding: 22px;
    }
    .product-lane h2 {
      margin-top: 8px;
      font-size: 1.25rem;
      letter-spacing: 0;
    }
    .skill-lab {
      display: grid;
      grid-template-columns: minmax(240px, 0.82fr) minmax(0, 1.5fr);
      gap: 20px;
      margin-top: 28px;
      padding-top: 28px;
      border-top: 1px solid var(--border);
    }
    .lab-intro {
      display: grid;
      align-content: start;
      gap: 8px;
    }
    .lab-intro h2 {
      font-size: 1.24rem;
      letter-spacing: 0;
    }
    .lab-intro p:not(.eyebrow) {
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.68;
    }
    .lab-grid {
      display: grid;
      gap: 12px;
    }
    .lab-item {
      display: grid;
      gap: 12px;
      min-width: 0;
      border: 1px solid rgba(148, 163, 184, 0.22);
      border-radius: 8px;
      padding: 18px;
      background: var(--desk-lab-card-bg);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.2);
    }
    .lab-topline {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
      justify-content: space-between;
    }
    .lab-item .card-kicker {
      color: var(--desk-lab-kicker);
    }
    .status-pill {
      display: inline-flex;
      width: fit-content;
      border: 1px solid rgba(251, 191, 36, 0.36);
      border-radius: 999px;
      padding: 4px 9px;
      color: var(--desk-status-text);
      background: var(--desk-status-bg);
      font-size: 0.74rem;
      font-weight: 800;
      line-height: 1.35;
    }
    .lab-item h3 {
      font-size: 1.05rem;
      letter-spacing: 0;
    }
    .lab-item p {
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.65;
    }
    .validation-note {
      display: grid;
      gap: 5px;
      border-left: 2px solid rgba(34, 211, 238, 0.36);
      border-radius: 6px;
      padding: 9px 10px;
      background: rgba(34, 211, 238, 0.055);
    }
    .validation-note strong {
      color: var(--desk-validation-strong);
      font-size: 0.78rem;
      line-height: 1.3;
    }
    .validation-note span {
      color: var(--desk-validation-text);
      font-size: 0.84rem;
      line-height: 1.6;
    }
    .lab-chips {
      align-self: start;
    }
    .lane-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .lane-grid article {
      padding: 16px;
      box-shadow: none;
      background: var(--desk-chip-bg);
    }
    .lane-grid h3 {
      font-size: 0.98rem;
      letter-spacing: 0;
    }
    .lane-grid p {
      color: var(--muted);
      font-size: 0.86rem;
      line-height: 1.6;
      margin-top: 6px;
    }
    .harness-link {
      display: inline-flex;
      margin-top: 24px;
      color: var(--desk-harness);
      font-weight: 700;
    }
    .harness-link:hover {
      color: var(--text);
    }
    @media (max-width: 900px) {
      .desk-grid,
      .product-lane,
      .skill-lab {
        grid-template-columns: 1fr;
      }
      .desk-hero h1 {
        font-size: 3.4rem;
      }
    }
    @media (max-width: 560px) {
      .desk-stats,
      .lane-grid {
        grid-template-columns: 1fr;
      }
      .desk-hero h1 {
        font-size: 2.5rem;
      }
      .skill-card {
        min-height: 0;
      }
    }
  </style>
</BaseLayout>
