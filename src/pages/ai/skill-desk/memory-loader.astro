---
import DeckLayout from '../../../layouts/DeckLayout.astro';
import { memoryLoaderSections, memoryLoaderTimeline } from '../../../data/skillDesk';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<DeckLayout
  title="memory-loader Skill：给 AI 记忆加控制层 — QQ星"
  description="从把知识塞进 skill，到隐藏 skill、共享目录、索引机制和 context-pack，讲 memory-loader 如何控制 AI 此刻该读什么。"
>
  <main id="deck" class="skill-method-deck memory-deck">
    <section id="s1">
      <div class="chapter">Skill Desk · 方法子页</div>
      <h1>memory-loader Skill：给 AI 记忆加控制层</h1>
      <p class="sub hero-copy">当 skill、知识卡和 agent 都变多以后，真正重要的不是让 AI 记得更多，而是让它知道此刻该读什么、为什么读、以及什么不该读。</p>
      <div class="route-strip" aria-label="memory-loader route">
        {['知识塞进 skill', '隐藏 skill', '共享目录', '索引路由', 'context-pack', '受控读取'].map((item, index) => (
          <>
            <span>{item}</span>
            {index < 5 && <i>-></i>}
          </>
        ))}
      </div>
      <div class="context-console" aria-label="context-pack preview">
        <div class="console-top">
          <span>memory-loader</span>
          <b>control layer</b>
        </div>
        <div class="console-grid">
          <span>当前任务</span><b>PRD 审查 / 报价 / 复盘</b>
          <span>最终加载</span><b>2-5 张正式卡 + 1-3 条能力规则</b>
          <span>未加载</span><b>全量 Vault / 旧 wiki / 弱相关原文</b>
          <span>风险</span><b>过期、冲突、缺证据、待确认</b>
        </div>
      </div>
      <div class="scroll-hint">↓ 进入记忆控制层演化</div>
    </section>

    {memoryLoaderSections.map((section) => (
      <section id={section.id}>
        <div class="chapter">{section.label}</div>
        <h2>{section.heading}</h2>
        <div class="method-layout">
          <div class="method-copy">
            <div class="lens">{section.chapter}</div>
            <p>{section.insight}</p>
            <ul>
              {section.points.map((point) => <li>{point}</li>)}
            </ul>
            {section.id === 's10' && (
              <div class="link-row">
                <a class="method-link" href={`${base}ai/skill-desk/`}>回到 Skill Desk</a>
                <a class="method-link secondary" href={`${base}ai/knowledge-harness/`}>查看 Knowledge Harness</a>
                <a class="method-link tertiary" href={`${base}ai/skill-desk/weekly-retro/`}>查看周度复盘</a>
              </div>
            )}
          </div>
          <div class="figure control-figure">
            <div class="fig-label">{section.visualTitle}</div>
            <div class={`visual-items visual-${section.id}`}>
              {section.visualItems.map((item) => <span>{item}</span>)}
            </div>
          </div>
        </div>
      </section>
    ))}
  </main>

  <nav class="timeline" id="tl" aria-label="Deck timeline">
    {memoryLoaderTimeline.map(([id, label]) => (
      <a href={`#${id}`} data-t={id}><span class="dot"></span><span class="lbl">{label}</span></a>
    ))}
  </nav>

  <script is:inline>
    const links = document.querySelectorAll('#tl a[data-t]');
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          links.forEach(l => l.classList.toggle('active', l.dataset.t === e.target.id));
        }
      });
    }, { root: document.getElementById('deck'), threshold: 0.55 });
    document.querySelectorAll('main section').forEach(s => obs.observe(s));
  </script>

  <style>
    .memory-deck {
      background:
        linear-gradient(180deg, rgba(34,211,238,0.045), rgba(255,255,255,0) 45%),
        linear-gradient(120deg, rgba(52,211,153,0.075), transparent 34%),
        radial-gradient(circle at 52% 28%, rgba(251,191,36,0.08), transparent 34%);
    }
    .hero-copy {
      margin-top: 1.35rem;
    }
    .route-strip,
    .visual-items,
    .link-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
      align-items: center;
      justify-content: center;
    }
    .route-strip {
      margin-top: 1.8rem;
      max-width: 940px;
    }
    .route-strip span,
    .visual-items span {
      color: var(--text);
      border: 1px solid rgba(34,211,238,0.45);
      background: rgba(34,211,238,0.1);
      border-radius: 999px;
      padding: 0.5rem 0.78rem;
      font-size: 0.82rem;
      line-height: 1.35;
    }
    .route-strip i {
      color: var(--text-dim);
      font-style: normal;
    }
    .context-console {
      width: min(100%, 760px);
      margin-top: 1.5rem;
      border: 1px solid rgba(255,255,255,0.13);
      border-radius: 16px;
      overflow: hidden;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.025)),
        rgba(7,13,27,0.88);
      box-shadow: 0 24px 54px rgba(0,0,0,0.34);
    }
    .console-top {
      display: flex;
      gap: 0.75rem;
      align-items: center;
      justify-content: space-between;
      padding: 0.78rem 1rem;
      border-bottom: 1px solid rgba(255,255,255,0.1);
      color: #bdf7ff;
      font-size: 0.82rem;
      font-weight: 800;
    }
    .console-top b {
      color: #f8e7b2;
      font-size: 0.74rem;
      font-weight: 800;
      text-transform: uppercase;
    }
    .console-grid {
      display: grid;
      grid-template-columns: minmax(88px, 0.48fr) minmax(0, 1.52fr);
    }
    .console-grid span,
    .console-grid b {
      min-width: 0;
      border-right: 1px solid rgba(255,255,255,0.08);
      border-bottom: 1px solid rgba(255,255,255,0.08);
      padding: 0.68rem 0.82rem;
      color: var(--text);
      font-size: 0.78rem;
      line-height: 1.42;
    }
    .console-grid span {
      color: #8deff5;
      background: rgba(34,211,238,0.08);
      font-weight: 800;
    }
    .console-grid b {
      font-weight: 650;
    }
    .method-layout {
      display: grid;
      grid-template-columns: minmax(300px, 470px) minmax(320px, 570px);
      gap: 3rem;
      align-items: center;
      width: min(100%, 1080px);
    }
    .method-copy {
      display: grid;
      gap: 0.9rem;
      min-width: 0;
    }
    .lens,
    .fig-label {
      color: #22d3ee;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0;
      text-transform: uppercase;
    }
    .method-copy > p {
      color: var(--text);
      font-size: 1rem;
      line-height: 1.78;
    }
    .method-copy ul {
      display: grid;
      gap: 0.52rem;
      padding-left: 1.05rem;
      color: var(--text-dim);
      font-size: 0.9rem;
      line-height: 1.62;
    }
    .control-figure {
      min-width: 0;
      border-radius: 18px;
    }
    .visual-items {
      justify-content: flex-start;
      margin-top: 1rem;
    }
    .visual-s2 span:nth-child(1),
    .visual-s3 span:nth-child(4),
    .visual-s6 span:nth-child(5) {
      border-color: rgba(251,113,133,0.5);
      background: rgba(251,113,133,0.13);
    }
    .visual-s4 span:nth-child(2),
    .visual-s7 span:nth-child(4),
    .visual-s8 span:nth-child(4) {
      border-color: rgba(251,191,36,0.52);
      background: rgba(251,191,36,0.12);
    }
    .visual-s5 span:nth-child(4),
    .visual-s9 span:nth-child(1),
    .visual-s10 span:nth-child(1) {
      border-color: rgba(52,211,153,0.52);
      background: rgba(52,211,153,0.12);
    }
    .method-link {
      display: inline-flex;
      width: fit-content;
      color: var(--text);
      border: 1px solid rgba(34,211,238,0.48);
      border-radius: 999px;
      padding: 0.52rem 0.9rem;
      background: rgba(34,211,238,0.1);
      font-size: 0.88rem;
      font-weight: 700;
    }
    .method-link.secondary {
      border-color: rgba(52,211,153,0.45);
      background: rgba(52,211,153,0.1);
    }
    .method-link.tertiary {
      border-color: rgba(251,191,36,0.45);
      background: rgba(251,191,36,0.1);
    }
    .link-row {
      justify-content: flex-start;
    }
    @media (max-width: 860px) {
      .memory-deck section {
        padding-top: 5.2rem;
        padding-bottom: 6.9rem;
      }
      .method-layout {
        grid-template-columns: 1fr;
        gap: 1.6rem;
      }
      .control-figure {
        width: min(100%, 480px);
      }
      .route-strip {
        justify-content: flex-start;
      }
    }
    @media (max-width: 560px) {
      .context-console {
        border-radius: 10px;
      }
      .console-top {
        align-items: flex-start;
        flex-direction: column;
        gap: 0.3rem;
      }
      .console-grid {
        grid-template-columns: 1fr;
      }
      .console-grid span,
      .console-grid b {
        padding: 0.5rem 0.58rem;
        font-size: 0.68rem;
      }
      .console-grid span {
        border-bottom: 0;
      }
      .control-figure {
        padding: 1rem;
      }
      .route-strip span,
      .visual-items span {
        font-size: 0.72rem;
        padding: 0.42rem 0.62rem;
      }
      .memory-deck .scroll-hint {
        display: none;
      }
      .route-strip i {
        display: none;
      }
    }
  </style>
</DeckLayout>
