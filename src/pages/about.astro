---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/Timeline.astro';
import SkillTags from '../components/SkillTags.astro';
import { profile } from '../data/profile';
const base = import.meta.env.BASE_URL;
---
<BaseLayout title={`关于 · ${profile.name}`} description={profile.summary}>
  <section class="section-pad">
    <div class="container about">
      <h1>{profile.name}</h1>
      <p class="intent">{profile.intent}</p>
      <p class="summary">{profile.summary}</p>
      <div class="cta">
        <a class="btn" href={`${base}${profile.resumePdf}`} download>⬇ 下载 PDF 简历</a>
        <a class="btn ghost" href={`mailto:${profile.email}`}>✉ 联系我</a>
      </div>
      <Timeline />
      <h3 class="sec-h">技能</h3>
      <SkillTags />
      <h3 class="sec-h">链接</h3>
      <div class="links">
        {profile.links.map((l) => <a href={l.href} target="_blank" rel="noopener">{l.label}</a>)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about { max-width: 780px; }
  .about h1 { font-size: 32px; }
  .intent { color: var(--accent); font-weight: 600; margin-top: 8px; }
  .summary { color: var(--muted); margin-top: 8px; }
  .cta { display: flex; gap: 12px; margin: 20px 0 8px; flex-wrap: wrap; }
  .btn { background: var(--accent); color:#fff; border-radius:999px; padding:8px 18px; font-size:14px; }
  .btn.ghost { background: transparent; border:1px solid var(--accent); color: var(--accent); }
  .sec-h { margin: 28px 0 12px; }
  .links { display: flex; gap: 16px; flex-wrap: wrap; }
</style>
