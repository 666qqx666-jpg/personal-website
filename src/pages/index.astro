---
import BaseLayout from '../layouts/BaseLayout.astro';
import Banner from '../components/Banner.astro';
import SectionGrid from '../components/SectionGrid.astro';
import { profile } from '../data/profile';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const sections = [
  { title: '项目经历', hook: '做过的产品 / 项目，方法论融入案例', href: `${base}projects/`, cover: 'linear-gradient(135deg,#6366f1,#a855f7)' },
  { title: 'AI 落地实战', hook: '把 AI 嵌进 PM 工作流的动手证据', href: `${base}ai/`, cover: 'linear-gradient(135deg,#a855f7,#06b6d4)' },
  { title: '思考与成长', hook: '读书笔记 · 方法论 · 转型故事', href: `${base}thinking/`, cover: 'linear-gradient(135deg,#06b6d4,#6366f1)' },
];
---
<BaseLayout title={`${profile.name} · 个人主页`} description={profile.summary}>
  <Banner />
  <SectionGrid title="作品与思考" items={sections} />
</BaseLayout>
