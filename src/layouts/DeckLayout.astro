---
// deck 默认跟随主站主题；需要固定暗色时显式传 themeMode="fixed-dark"。
interface Props { title: string; description?: string; themeMode?: 'fixed-dark' | 'site'; }
const { title, description = '', themeMode = 'site' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const syncSiteTheme = themeMode === 'site';
---
<!doctype html>
<html lang="zh-CN" data-deck-theme={themeMode}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        if (root.dataset.deckTheme !== 'site') return;
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || stored === 'light') {
          root.dataset.theme = stored;
          return;
        }
        root.dataset.theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      })();
    </script>
  </head>
  <body class={syncSiteTheme ? 'deck-site-theme' : undefined}>
    <div class="aurora"></div>
    <a class="deck-back" href={base}>← QQ星</a>
    {syncSiteTheme && <button id="deck-theme-toggle" class="deck-theme-toggle" aria-label="切换深浅色" title="切换深浅色">🌙</button>}
    <slot />
    {syncSiteTheme && (
      <script is:inline>
        (() => {
          const root = document.documentElement;
          const btn = document.getElementById('deck-theme-toggle');
          const sync = () => {
            const dark = root.dataset.theme === 'dark';
            if (btn) btn.textContent = dark ? '☀️' : '🌙';
          };
          sync();
          btn?.addEventListener('click', () => {
            const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
            root.dataset.theme = next;
            localStorage.setItem('theme', next);
            sync();
          });
        })();
      </script>
    )}
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #070b14;
    --grid: rgba(120, 140, 200, 0.07);
    --text: #e8ecf5;
    --text-dim: #9aa5bd;
    --glass: rgba(255, 255, 255, 0.055);
    --glass-border: rgba(255, 255, 255, 0.12);
    --c-blue: #4f8cff;
    --c-violet: #8b5cf6;
    --c-cyan: #22d3ee;
    --c-problem: #fb7185;
    --c-think: #60a5fa;
    --c-decide: #34d399;
    --grad: linear-gradient(100deg, #4f8cff 0%, #8b5cf6 50%, #22d3ee 100%);
    --chrome-bg: rgba(10, 15, 28, 0.72);
    --timeline-line: rgba(255, 255, 255, 0.15);
    --dot-muted: rgba(255, 255, 255, 0.22);
    --dot-future: rgba(255, 255, 255, 0.3);
    --aurora-blue: rgba(79, 140, 255, 0.16);
    --aurora-violet: rgba(139, 92, 246, 0.14);
    --aurora-cyan: rgba(34, 211, 238, 0.1);
  }
  :root[data-deck-theme='site'][data-theme='light'] {
    color-scheme: light;
    --bg: #f7f9fd;
    --grid: rgba(15, 23, 42, 0.055);
    --text: #0f172a;
    --text-dim: #5b677c;
    --glass: rgba(255, 255, 255, 0.78);
    --glass-border: rgba(15, 23, 42, 0.1);
    --c-blue: #2563eb;
    --c-violet: #7c3aed;
    --c-cyan: #0891b2;
    --c-problem: #e11d48;
    --c-think: #2563eb;
    --c-decide: #059669;
    --grad: linear-gradient(100deg, #2563eb 0%, #7c3aed 48%, #0891b2 100%);
    --chrome-bg: rgba(255, 255, 255, 0.78);
    --timeline-line: rgba(15, 23, 42, 0.14);
    --dot-muted: rgba(15, 23, 42, 0.24);
    --dot-future: rgba(15, 23, 42, 0.34);
    --aurora-blue: rgba(37, 99, 235, 0.13);
    --aurora-violet: rgba(124, 58, 237, 0.1);
    --aurora-cyan: rgba(8, 145, 178, 0.09);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", -apple-system, sans-serif;
    overflow-x: hidden;
  }
  .deck-back {
    position: fixed; top: 1.1rem; left: 1.2rem; z-index: 20;
    color: var(--text-dim); text-decoration: none; font-size: 0.85rem;
    background: var(--chrome-bg); border: 1px solid var(--glass-border);
    border-radius: 999px; padding: 0.45rem 0.95rem; backdrop-filter: blur(16px);
    transition: color 0.25s;
  }
  .deck-back:hover { color: var(--text); }
  .deck-theme-toggle {
    position: fixed; top: 1.1rem; right: 1.2rem; z-index: 20;
    width: 38px; height: 38px; border-radius: 999px;
    border: 1px solid var(--glass-border); background: var(--chrome-bg);
    color: var(--text); cursor: pointer; backdrop-filter: blur(16px);
    font-size: 16px; line-height: 1;
  }
  /* ===== aurora 背景 ===== */
  .aurora {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background:
      radial-gradient(600px 400px at 15% 20%, var(--aurora-blue), transparent 65%),
      radial-gradient(700px 500px at 85% 15%, var(--aurora-violet), transparent 65%),
      radial-gradient(800px 600px at 50% 95%, var(--aurora-cyan), transparent 65%);
  }
  .aurora::after {
    content: ""; position: absolute; inset: 0;
    background-image:
      linear-gradient(var(--grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 90% 80% at 50% 40%, #000 30%, transparent 100%);
  }
  /* ===== scroll-snap 容器（100vh fallback + dvh 升级） ===== */
  main {
    position: relative; z-index: 1;
    height: 100vh;
    overflow-y: scroll;
    scroll-snap-type: y mandatory;
  }
  section {
    height: 100vh;
    scroll-snap-align: start;
    display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    padding: 4.5rem 6vw 7.5rem;
    position: relative;
  }
  @supports (height: 100dvh) {
    main { height: 100dvh; }
    section { height: 100dvh; }
  }
  .chapter {
    font-size: 0.82rem; letter-spacing: 0.35em; color: var(--text-dim);
    text-transform: uppercase; margin-bottom: 1rem;
  }
  h1 {
    font-size: clamp(2.4rem, 6vw, 4.6rem); font-weight: 800; line-height: 1.15;
    background: var(--grad); -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent; text-align: center;
  }
  h2 {
    font-size: clamp(1.5rem, 3.2vw, 2.4rem); font-weight: 700; line-height: 1.3;
    margin-bottom: 1.6rem; text-align: center;
  }
  h2 em {
    font-style: normal;
    background: var(--grad); -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .sub { color: var(--text-dim); font-size: clamp(1rem, 1.6vw, 1.2rem); text-align: center; max-width: 640px; line-height: 1.8; }
  /* ===== 问题/思考/决策 微结构 ===== */
  .ptd { display: grid; gap: 0.9rem; max-width: 460px; }
  .ptd-row { display: flex; gap: 0.8rem; align-items: flex-start; }
  .pill {
    flex-shrink: 0; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em;
    padding: 0.28rem 0.7rem; border-radius: 999px; margin-top: 0.15rem;
  }
  .pill.p { color: var(--c-problem); background: rgba(251, 113, 133, 0.12); border: 1px solid rgba(251, 113, 133, 0.35); }
  .pill.t { color: var(--c-think);  background: rgba(96, 165, 250, 0.12);  border: 1px solid rgba(96, 165, 250, 0.35); }
  .pill.d { color: var(--c-decide); background: rgba(52, 211, 153, 0.12);  border: 1px solid rgba(52, 211, 153, 0.35); }
  .ptd-row p { font-size: 0.98rem; line-height: 1.75; color: var(--text); }
  .ptd-row p small { color: var(--text-dim); display: block; font-size: 0.85rem; }
  /* ===== 左文右图布局 ===== */
  .split { display: grid; grid-template-columns: minmax(300px, 440px) minmax(320px, 560px); gap: 4vw; align-items: center; }
  .figure {
    background: var(--glass); border: 1px solid var(--glass-border); border-radius: 20px;
    padding: 1.6rem; backdrop-filter: blur(14px); box-shadow: 0 18px 50px rgba(0,0,0,0.35);
  }
  .figure svg { width: 100%; height: auto; display: block; }
  :root[data-deck-theme='site'][data-theme='light'] svg text[fill="#e8ecf5"],
  :root[data-deck-theme='site'][data-theme='light'] svg text[fill="#dbeafe"] {
    fill: var(--text);
  }
  :root[data-deck-theme='site'][data-theme='light'] svg text[fill="#9aa5bd"] {
    fill: var(--text-dim);
  }
  .figcap { text-align: center; color: var(--text-dim); font-size: 0.8rem; margin-top: 0.8rem; }
  /* ===== 底部时间轴导航 ===== */
  nav.timeline {
    position: fixed; left: 50%; bottom: 1.1rem; transform: translateX(-50%);
    z-index: 10; display: flex; align-items: center; gap: 0;
    background: var(--chrome-bg); border: 1px solid var(--glass-border);
    border-radius: 999px; padding: 0.55rem 1.1rem; backdrop-filter: blur(16px);
  }
  nav.timeline a {
    display: flex; flex-direction: column; align-items: center; gap: 0.28rem;
    text-decoration: none; color: var(--text-dim); font-size: 0.62rem;
    padding: 0 0.7rem; position: relative; white-space: nowrap; transition: color 0.25s;
  }
  nav.timeline a .dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--dot-muted); transition: all 0.25s;
  }
  nav.timeline a:not(:last-child)::after {
    content: ""; position: absolute; right: -0.35rem; top: 4px;
    width: 0.7rem; height: 1px; background: var(--timeline-line);
  }
  nav.timeline a.active { color: var(--text); }
  nav.timeline a.active .dot { background: var(--grad); box-shadow: 0 0 10px rgba(139, 92, 246, 0.9); transform: scale(1.35); }
  nav.timeline a.future .dot { background: transparent; border: 1px dashed var(--dot-future); }
  /* ===== 数字板 ===== */
  .stats { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem; max-width: 900px; width: 100%; }
  .stat {
    background: var(--glass); border: 1px solid var(--glass-border); border-radius: 16px;
    padding: 1.4rem 0.6rem; text-align: center; backdrop-filter: blur(14px);
  }
  .stat b {
    display: block; font-size: clamp(1.8rem, 3.4vw, 2.8rem); font-weight: 800;
    background: var(--grad); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .stat span { color: var(--text-dim); font-size: 0.82rem; }
  .scroll-hint {
    position: absolute; bottom: 5.2rem; left: 50%; transform: translateX(-50%);
    color: var(--text-dim); font-size: 0.8rem; animation: bob 2s infinite ease-in-out;
  }
  @keyframes bob { 0%,100% { transform: translate(-50%, 0); } 50% { transform: translate(-50%, 8px); } }
  .quote {
    border-left: 3px solid; border-image: var(--grad) 1;
    padding: 0.4rem 0 0.4rem 1.1rem; margin-top: 1.4rem;
    color: var(--text-dim); font-size: 0.92rem; line-height: 1.7; max-width: 440px;
  }
  svg text { font-family: inherit; }
  @media (max-width: 860px) {
    .split { grid-template-columns: 1fr; gap: 1.6rem; }
    .figure { max-width: 480px; }
    h2 { margin-bottom: 1.05rem; }
    .stats { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
    .stat { padding: 1rem 0.5rem; }
    .stat b { font-size: clamp(1.7rem, 9vw, 2.25rem); }
    nav.timeline a span.lbl { display: none; }
    #s10 .stats + div { margin-top: 1.35rem !important; gap: 0.65rem !important; }
    #s10 .sub { margin-top: 1.15rem !important; }
    section {
      height: auto;
      min-height: 100vh;
      padding: 4.75rem 6vw 7rem;
    }
    @supports (height: 100dvh) {
      section { min-height: 100dvh; }
    }
  }
</style>
